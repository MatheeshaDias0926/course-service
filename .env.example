# Server
PORT=3002
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/course-service?retryWrites=true&w=majority

# Auth Service URL (for JWT validation via inter-service call)
AUTH_SERVICE_URL=http://localhost:3001

# JWT (shared secret with Auth Service for local validation)
JWT_SECRET=your-super-secret-jwt-key-change-this

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003,http://localhost:3004

# Notification Service (SNS/SQS)
AWS_REGION=us-east-1
SNS_ENROLLMENT_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:enrollment-events

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
